---
import '../styles/masthead.css';
---

<header class="masthead">
  <div class="masthead-logo">
    <img src="/vyeos.png" alt="VYEOS" class="logo-mark" />
  </div>
      <nav class="masthead-nav">
        <a href="/">Home</a>
        <a href="/blog">Blog</a>
        <a href="/resume.pdf" target="_blank" rel="noopener noreferrer">Resume</a>
      </nav>
  <button class="masthead-toggle" type="button" aria-label="Toggle navigation">
    <span></span>
  </button>
  <div class="masthead-theme">Rose Pine</div>
</header>

<script>
  const masthead = document.querySelector('.masthead');
  const toggle = document.querySelector('.masthead-toggle');

  if (masthead && toggle) {
    toggle.addEventListener('click', () => {
      masthead.classList.toggle('is-open');
    });
  }
</script>
