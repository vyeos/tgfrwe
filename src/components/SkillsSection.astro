---
import '../styles/skills.css';
import type { PersonalInfo, Skill, SkillCategory } from '../types/portfolio';

const { personalInfo, skills } = Astro.props as {
  personalInfo: PersonalInfo;
  skills: Skill[];
};

const isCategory = (category: SkillCategory) => (skill: Skill) =>
  skill.category === category;
---

<section class="skills-section">
  <div class="skills-sidebar">
    <h3>Frontend Developer with Full-Stack Capabilities</h3>
    <p>{personalInfo.bio}</p>
  </div>
  <div class="skills-grid">
    <div class="skill-category">
      <div class="skill-category-title">Primary Stack</div>
      <div class="skill-list">
            {skills.filter(isCategory('primary')).map((skill: Skill) => (
              <span class="skill-tag">{skill.name}</span>
            ))}
      </div>
    </div>
    <div class="skill-category">
      <div class="skill-category-title">Languages</div>
      <div class="skill-list">
            {skills.filter(isCategory('language')).map((skill: Skill) => (
              <span class="skill-tag">{skill.name}</span>
            ))}
      </div>
    </div>
    <div class="skill-category">
      <div class="skill-category-title">Tools & Frameworks</div>
      <div class="skill-list">
            {skills.filter(isCategory('tool')).map((skill: Skill) => (
              <span class={`skill-tag ${skill.name === 'Neovim' ? 'accent' : ''}`}>{skill.name}</span>
            ))}
      </div>
    </div>
    <div class="skill-category">
      <div class="skill-category-title">Databases</div>
      <div class="skill-list">
            {skills.filter(isCategory('database')).map((skill: Skill) => (
              <span class="skill-tag">{skill.name}</span>
            ))}
      </div>
    </div>
  </div>
</section>
