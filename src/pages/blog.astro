---
import '../styles/global.css';
import '../styles/blog.css';
import { siteMetadata, personalInfo } from '../data/portfolio';
import Masthead from '../components/Masthead.astro';
import FooterSection from '../components/FooterSection.astro';
import { getCached } from '../lib/hive-cache';
import { ViewTransitions } from 'astro:transitions';

const posts: PostSummary[] = [];

const apiBaseUrl = import.meta.env.HIVE_API_URL ?? 'https://api.hivecms.online/api/public/v1';
const apiKey = import.meta.env.HIVE_API_KEY;

type PostSummary = {
  title: string;
  slug: string;
  excerpt: string;
  publishedAt: string | null;
  updatedAt: string | null;
  category: { name: string; slug: string } | null;
  tags: Array<{ name: string; slug: string }>;
  author: { id: string; name: string } | null;
};

type PostListResponse = {
  data: PostSummary[];
  total: number;
  offset: number;
  limit: number;
};

if (apiKey) {
  try {
    const listUrl = new URL(`${apiBaseUrl}/${apiKey}/posts`);
    listUrl.searchParams.set('limit', '50');

    const data = await getCached('hive:list', async () => {
      const response = await fetch(listUrl.toString(), {
        headers: {},
      });

      if (!response.ok) {
        return { data: [], total: 0, offset: 0, limit: 0 } as PostListResponse;
      }
      return (await response.json()) as PostListResponse;
    });

    if (Array.isArray(data?.data)) {
      posts.push(...data.data);
    }
  } catch (error) {
    // Swallow errors to keep page rendering.
  }
}

const getCoverImage = (post: unknown) => {
  if (!post || typeof post !== 'object') return '';
  const record = post as Record<string, unknown>;
  const candidates = [
    record.coverImage,
    record.cover_image,
    record.image,
    record.thumbnail,
    record.thumbnail_url,
    record.featured_image,
    record.hero_image,
  ];

  const found = candidates.find((item) => typeof item === 'string');
  return typeof found === 'string' ? found : '';
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={`Blog — ${siteMetadata.description}`} />
    <title>{`Blog | ${siteMetadata.title}`}</title>
    <ViewTransitions />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  </head>

  <body>
    <Masthead />

    <main class="blog-main">
      <section class="blog-hero">
        <p class="blog-kicker">Field Notes</p>
        <h1>Writing about systems, interfaces, and the craft of shipping.</h1>
        <p class="blog-subhead">
          Notes from building products, debugging performance, and obsessing over UI details.
          Expect practical writeups, experiments, and sharp takes.
        </p>
        <div class="blog-meta">
          <span>New posts coming soon</span>
          <span class="blog-dot"></span>
          <span>{personalInfo.location.full}</span>
        </div>
      </section>

      <section class="blog-list">
        {posts.length ? (
          posts.map((post) => {
            const slug = post.slug;
            const cover = getCoverImage(post);
            return (
              <a class="blog-card" href={`/blog/${slug}`}>
                {cover ? (
                  <div class="blog-card-media">
                    <img src={cover} alt={post.title} loading="lazy" />
                  </div>
                ) : null}
                <div class="blog-card-header">
                  <span class="blog-tag">{post.category?.name || 'Article'}</span>
                  <span class="blog-date">{post.publishedAt ? new Date(post.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' }) : 'New'}</span>
                </div>
                <h2>{post.title}</h2>
                <p>{post.excerpt || 'Read the full post for details.'}</p>
              </a>
            );
          })
        ) : (
          <div class="blog-empty">
            <h2>No posts yet.</h2>
            <p>Once you publish on EasyBlog, they will show up here automatically.</p>
          </div>
        )}
      </section>
    </main>

    <FooterSection personalInfo={personalInfo} />
  </body>
</html>
