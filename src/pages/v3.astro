---
// Version 3: Minimalist Japanese / Zen Aesthetic
// Inspired by: Japanese design principles, wabi-sabi, zen gardens
// Aesthetic: Generous whitespace, subtle transitions, muted colors, refined typography
import { personalInfo, skills, projects, neovimHighlight, siteMetadata } from '../data/portfolio';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={siteMetadata.description} />
    <title>{siteMetadata.title} | v3</title>
    
    <!-- Noto Serif JP for refined Japanese-inspired typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Karla:wght@300;400;500&display=swap" rel="stylesheet">
    
    <style>
      :root {
        --bg: #faf9f7;
        --bg-secondary: #f5f3ef;
        --text: #2c2c2c;
        --text-light: #6b6b6b;
        --text-lighter: #9a9a9a;
        --accent: #c4a77d;
        --accent-dark: #8b7355;
        --border: #e8e5e0;
        --ink: #1a1a1a;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        font-size: 16px;
        scroll-behavior: smooth;
      }

      body {
        font-family: 'Karla', sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.8;
        font-weight: 300;
        letter-spacing: 0.02em;
      }

      ::selection {
        background: var(--accent);
        color: white;
      }

      /* Smooth fade-in animation */
      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .fade-in {
        animation: fadeIn 0.8s ease-out forwards;
      }

      /* Navigation */
      nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        padding: 2rem 4rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        z-index: 100;
        background: linear-gradient(to bottom, var(--bg) 60%, transparent);
      }

      .nav-logo {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.5rem;
        font-weight: 300;
        letter-spacing: 0.1em;
        color: var(--ink);
      }

      .nav-links {
        display: flex;
        gap: 3rem;
        list-style: none;
      }

      .nav-links a {
        color: var(--text-light);
        text-decoration: none;
        font-size: 0.85rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        position: relative;
        transition: color 0.3s ease;
      }

      .nav-links a::after {
        content: '';
        position: absolute;
        bottom: -4px;
        left: 0;
        width: 0;
        height: 1px;
        background: var(--accent);
        transition: width 0.4s ease;
      }

      .nav-links a:hover {
        color: var(--ink);
      }

      .nav-links a:hover::after {
        width: 100%;
      }

      /* Hero Section */
      .hero {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 0 10vw;
        position: relative;
      }

      .hero-content {
        max-width: 800px;
      }

      .hero-greeting {
        font-size: 0.85rem;
        color: var(--text-lighter);
        letter-spacing: 0.2em;
        text-transform: uppercase;
        margin-bottom: 2rem;
      }

      .hero-name {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(3rem, 8vw, 6rem);
        font-weight: 300;
        line-height: 1.1;
        color: var(--ink);
        margin-bottom: 2rem;
        letter-spacing: -0.02em;
      }

      .hero-name em {
        font-style: italic;
        color: var(--accent-dark);
      }

      .hero-tagline {
        font-size: 1.1rem;
        color: var(--text-light);
        max-width: 500px;
        line-height: 1.9;
      }

      .hero-scroll {
        position: absolute;
        bottom: 4rem;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        color: var(--text-lighter);
        font-size: 0.7rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
      }

      .scroll-line {
        width: 1px;
        height: 60px;
        background: linear-gradient(to bottom, var(--border), var(--accent));
        animation: scrollPulse 2s ease-in-out infinite;
      }

      @keyframes scrollPulse {
        0%, 100% { opacity: 0.3; height: 60px; }
        50% { opacity: 1; height: 80px; }
      }

      /* Japanese decorative element */
      .hero-deco {
        position: absolute;
        right: 10vw;
        top: 50%;
        transform: translateY(-50%);
        writing-mode: vertical-rl;
        font-family: 'Cormorant Garamond', serif;
        font-size: 0.9rem;
        color: var(--border);
        letter-spacing: 0.5em;
        opacity: 0.5;
      }

      /* Section styling */
      section {
        padding: 10rem 10vw;
      }

      .section-header {
        display: flex;
        align-items: center;
        gap: 2rem;
        margin-bottom: 5rem;
      }

      .section-number {
        font-family: 'Cormorant Garamond', serif;
        font-size: 0.9rem;
        color: var(--accent);
      }

      .section-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 2.5rem;
        font-weight: 300;
        color: var(--ink);
        letter-spacing: 0.02em;
      }

      .section-line {
        flex: 1;
        height: 1px;
        background: var(--border);
      }

      /* About Section */
      .about-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 6rem;
      }

      .about-text {
        font-size: 1.05rem;
        line-height: 2;
        color: var(--text);
      }

      .about-text p + p {
        margin-top: 1.5rem;
      }

      .about-details {
        padding-top: 1rem;
      }

      .detail-item {
        padding: 1.5rem 0;
        border-bottom: 1px solid var(--border);
        display: flex;
        justify-content: space-between;
        align-items: baseline;
      }

      .detail-label {
        font-size: 0.75rem;
        color: var(--text-lighter);
        letter-spacing: 0.15em;
        text-transform: uppercase;
      }

      .detail-value {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.1rem;
        color: var(--ink);
      }

      /* Neovim Section - Zen card */
      .neovim-card {
        background: var(--bg-secondary);
        padding: 4rem;
        margin-top: 4rem;
        position: relative;
        overflow: hidden;
      }

      .neovim-card::before {
        content: 'vim';
        position: absolute;
        right: 2rem;
        top: 50%;
        transform: translateY(-50%);
        font-family: 'Cormorant Garamond', serif;
        font-size: 15rem;
        color: var(--border);
        opacity: 0.3;
        line-height: 1;
      }

      .neovim-label {
        font-size: 0.7rem;
        color: var(--accent);
        letter-spacing: 0.2em;
        text-transform: uppercase;
        margin-bottom: 1rem;
      }

      .neovim-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 2rem;
        font-weight: 300;
        color: var(--ink);
        margin-bottom: 1.5rem;
      }

      .neovim-desc {
        font-size: 1rem;
        line-height: 1.9;
        color: var(--text-light);
        max-width: 600px;
        position: relative;
        z-index: 1;
      }

      /* Skills Section */
      .skills-container {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 3rem;
      }

      .skill-group {
        padding: 2rem 0;
      }

      .skill-group-title {
        font-size: 0.7rem;
        color: var(--text-lighter);
        letter-spacing: 0.2em;
        text-transform: uppercase;
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid var(--border);
      }

      .skill-list {
        list-style: none;
      }

      .skill-item {
        padding: 0.75rem 0;
        font-size: 0.95rem;
        color: var(--text);
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid transparent;
        transition: all 0.3s ease;
      }

      .skill-item:hover {
        border-bottom-color: var(--border);
        padding-left: 0.5rem;
      }

      .skill-item.highlight {
        color: var(--accent-dark);
        font-weight: 500;
      }

      .skill-level {
        width: 40px;
        height: 3px;
        background: var(--border);
        position: relative;
        overflow: hidden;
      }

      .skill-level::after {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        height: 100%;
        background: var(--accent);
        transition: width 0.6s ease;
      }

      .skill-item[data-level="expert"] .skill-level::after { width: 100%; }
      .skill-item[data-level="advanced"] .skill-level::after { width: 75%; }
      .skill-item[data-level="intermediate"] .skill-level::after { width: 50%; }

      /* Projects Section */
      .projects-list {
        display: flex;
        flex-direction: column;
      }

      .project-item {
        display: grid;
        grid-template-columns: auto 1fr auto;
        gap: 4rem;
        padding: 4rem 0;
        border-bottom: 1px solid var(--border);
        align-items: center;
        transition: all 0.4s ease;
      }

      .project-item:first-child {
        border-top: 1px solid var(--border);
      }

      .project-item:hover {
        padding-left: 1rem;
        background: linear-gradient(to right, var(--bg-secondary), transparent);
      }

      .project-number {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1rem;
        color: var(--text-lighter);
        min-width: 3rem;
      }

      .project-info {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }

      .project-name {
        font-family: 'Cormorant Garamond', serif;
        font-size: 2rem;
        font-weight: 400;
        color: var(--ink);
        transition: color 0.3s ease;
      }

      .project-item:hover .project-name {
        color: var(--accent-dark);
      }

      .project-desc {
        font-size: 0.9rem;
        color: var(--text-light);
        max-width: 400px;
      }

      .project-desc.placeholder {
        font-style: italic;
        color: var(--text-lighter);
      }

      .project-link {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--text-light);
        text-decoration: none;
        font-size: 0.8rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        transition: color 0.3s ease;
      }

      .project-link:hover {
        color: var(--accent-dark);
      }

      .project-link svg {
        width: 16px;
        height: 16px;
        transition: transform 0.3s ease;
      }

      .project-link:hover svg {
        transform: translateX(4px);
      }

      /* Contact Section */
      .contact-content {
        text-align: center;
        max-width: 600px;
        margin: 0 auto;
      }

      .contact-headline {
        font-family: 'Cormorant Garamond', serif;
        font-size: 3rem;
        font-weight: 300;
        color: var(--ink);
        margin-bottom: 2rem;
        line-height: 1.3;
      }

      .contact-headline em {
        font-style: italic;
        color: var(--accent-dark);
      }

      .contact-email {
        display: inline-block;
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.5rem;
        color: var(--accent-dark);
        text-decoration: none;
        padding: 1rem 0;
        border-bottom: 1px solid var(--accent);
        margin-top: 2rem;
        transition: all 0.3s ease;
      }

      .contact-email:hover {
        color: var(--ink);
        border-bottom-color: var(--ink);
        letter-spacing: 0.05em;
      }

      .contact-socials {
        display: flex;
        justify-content: center;
        gap: 3rem;
        margin-top: 4rem;
        padding-top: 4rem;
        border-top: 1px solid var(--border);
      }

      .social-link {
        color: var(--text-light);
        text-decoration: none;
        font-size: 0.8rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        transition: color 0.3s ease;
      }

      .social-link:hover {
        color: var(--accent-dark);
      }

      /* Footer */
      footer {
        padding: 4rem 10vw;
        text-align: center;
        border-top: 1px solid var(--border);
      }

      .footer-text {
        font-size: 0.8rem;
        color: var(--text-lighter);
        letter-spacing: 0.1em;
      }

      .footer-kanji {
        font-size: 2rem;
        color: var(--border);
        margin-bottom: 1rem;
      }

      /* Responsive */
      @media (max-width: 1024px) {
        nav {
          padding: 1.5rem 2rem;
        }

        .hero, section {
          padding: 6rem 2rem;
        }

        .about-grid {
          grid-template-columns: 1fr;
          gap: 3rem;
        }

        .skills-container {
          grid-template-columns: repeat(2, 1fr);
          gap: 2rem;
        }

        .hero-deco {
          display: none;
        }
      }

      @media (max-width: 768px) {
        .nav-links {
          display: none;
        }

        .hero-name {
          font-size: 2.5rem;
        }

        .skills-container {
          grid-template-columns: 1fr;
        }

        .project-item {
          grid-template-columns: 1fr;
          gap: 1rem;
        }

        .project-number {
          display: none;
        }

        .contact-socials {
          flex-direction: column;
          gap: 1.5rem;
        }
      }
    </style>
  </head>
  
  <body>
    <!-- Navigation -->
    <nav>
      <span class="nav-logo">RP</span>
      <ul class="nav-links">
        <li><a href="#about">About</a></li>
        <li><a href="#skills">Skills</a></li>
        <li><a href="#work">Work</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
    </nav>

    <!-- Hero -->
    <section class="hero">
      <div class="hero-content fade-in">
        <p class="hero-greeting">Hello, I'm</p>
        <h1 class="hero-name">{personalInfo.firstName} <em>{personalInfo.lastName}</em></h1>
        <p class="hero-tagline">{personalInfo.tagline}</p>
      </div>
      
      <div class="hero-scroll">
        <span>Scroll</span>
        <div class="scroll-line"></div>
      </div>
      
      <div class="hero-deco">Frontend Developer</div>
    </section>

    <!-- About Section -->
    <section id="about">
      <div class="section-header">
        <span class="section-number">01</span>
        <h2 class="section-title">About</h2>
        <div class="section-line"></div>
      </div>

      <div class="about-grid">
        <div class="about-text">
          <p>{personalInfo.bio.split('\n\n')[0]}</p>
          <p>{personalInfo.bio.split('\n\n')[1]}</p>
        </div>
        
        <div class="about-details">
          <div class="detail-item">
            <span class="detail-label">Location</span>
            <span class="detail-value">{personalInfo.location.city}, {personalInfo.location.country}</span>
          </div>
          <div class="detail-item">
            <span class="detail-label">Education</span>
            <span class="detail-value">{personalInfo.education.institution}</span>
          </div>
          <div class="detail-item">
            <span class="detail-label">Year</span>
            <span class="detail-value">{personalInfo.education.year}</span>
          </div>
          <div class="detail-item">
            <span class="detail-label">Focus</span>
            <span class="detail-value">{personalInfo.title}</span>
          </div>
        </div>
      </div>

      <!-- Neovim Highlight -->
      <div class="neovim-card">
        <span class="neovim-label">Primary Tool</span>
        <h3 class="neovim-title">{neovimHighlight.title}</h3>
        <p class="neovim-desc">{neovimHighlight.description}</p>
      </div>
    </section>

    <!-- Skills Section -->
    <section id="skills">
      <div class="section-header">
        <span class="section-number">02</span>
        <h2 class="section-title">Expertise</h2>
        <div class="section-line"></div>
      </div>

      <div class="skills-container">
        <div class="skill-group">
          <h3 class="skill-group-title">Primary Stack</h3>
          <ul class="skill-list">
            {skills.filter(s => s.category === 'primary').map(skill => (
              <li class="skill-item" data-level={skill.proficiency}>
                <span>{skill.name}</span>
                <span class="skill-level"></span>
              </li>
            ))}
          </ul>
        </div>

        <div class="skill-group">
          <h3 class="skill-group-title">Languages</h3>
          <ul class="skill-list">
            {skills.filter(s => s.category === 'language').map(skill => (
              <li class="skill-item" data-level={skill.proficiency}>
                <span>{skill.name}</span>
                <span class="skill-level"></span>
              </li>
            ))}
          </ul>
        </div>

        <div class="skill-group">
          <h3 class="skill-group-title">Tools</h3>
          <ul class="skill-list">
            {skills.filter(s => s.category === 'tool').map(skill => (
              <li class={`skill-item ${skill.name === 'Neovim' ? 'highlight' : ''}`} data-level={skill.proficiency}>
                <span>{skill.name}</span>
                <span class="skill-level"></span>
              </li>
            ))}
          </ul>
        </div>

        <div class="skill-group">
          <h3 class="skill-group-title">Databases</h3>
          <ul class="skill-list">
            {skills.filter(s => s.category === 'database').map(skill => (
              <li class="skill-item" data-level={skill.proficiency}>
                <span>{skill.name}</span>
                <span class="skill-level"></span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- Projects Section -->
    <section id="work">
      <div class="section-header">
        <span class="section-number">03</span>
        <h2 class="section-title">Selected Work</h2>
        <div class="section-line"></div>
      </div>

      <div class="projects-list">
        {projects.map((project, index) => (
          <article class="project-item">
            <span class="project-number">{String(index + 1).padStart(2, '0')}</span>
            <div class="project-info">
              <h3 class="project-name">{project.name}</h3>
              <p class={`project-desc ${!project.description ? 'placeholder' : ''}`}>
                {project.description || 'Details coming soon'}
              </p>
            </div>
            <a href={project.deployedUrl || project.githubUrl || '#'} class="project-link">
              View
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </article>
        ))}
      </div>
    </section>

    <!-- Contact Section -->
    <section id="contact">
      <div class="contact-content">
        <h2 class="contact-headline">
          Let's create something <em>meaningful</em> together
        </h2>
        <a href={`mailto:${personalInfo.email}`} class="contact-email">
          {personalInfo.email}
        </a>
        
        <div class="contact-socials">
          {personalInfo.socials.map(social => (
            <a href={social.url} class="social-link" target="_blank" rel="noopener noreferrer">
              {social.platform}
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer>
      <div class="footer-kanji">静</div>
      <p class="footer-text">&copy; 2024 {personalInfo.name}</p>
    </footer>
  </body>
</html>
