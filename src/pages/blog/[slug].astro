---
import '../../styles/global.css';
import '../../styles/blog.css';
import { personalInfo } from '../../data/portfolio';
import Masthead from '../../components/Masthead.astro';
import FooterSection from '../../components/FooterSection.astro';
import { ViewTransitions } from 'astro:transitions';

type EasyBlogPost = {
  title: string;
  project_id: string;
  word_count: number;
  author: string;
  author_id: string;
  slug: string;
  tags: string[];
  excerpt: string;
  category: string;
  created_at: string;
  updated_at: string;
  html_content?: string;
  html?: string;
  content_html?: string;
  content?: string;
  cover_image?: string;
  image?: string;
  thumbnail?: string;
  thumbnail_url?: string;
  featured_image?: string;
  hero_image?: string;
};

type EasyBlogDetailResponse = {
  blog: EasyBlogPost;
};

const { post } = Astro.props as { post: EasyBlogPost | null };

const getCoverImage = (post) =>
  post?.cover_image ||
  post?.image ||
  post?.thumbnail ||
  post?.thumbnail_url ||
  post?.featured_image ||
  post?.hero_image ||
  '';

export async function getStaticPaths() {
  const apiUrl = import.meta.env.EASYBLOG_API_URL ?? 'https://api.easyblog.io';
  const apiKey = import.meta.env.EASYBLOG_API_KEY;
  const projectId = import.meta.env.EASYBLOG_PROJECT_ID;

  if (!apiKey || !projectId) {
    return [];
  }

  try {
    const listUrl = new URL(`${apiUrl}/v1/blogs`);
    listUrl.searchParams.set('project_id', projectId);
    listUrl.searchParams.set('limit', '100');

    const listResponse = await fetch(listUrl.toString(), {
      headers: {
        'x-api-key': apiKey,
      },
    });

    if (!listResponse.ok) {
      return [];
    }

    const listData = (await listResponse.json()) as { blogs: EasyBlogPost[] };
    const blogs = Array.isArray(listData?.blogs) ? listData.blogs : [];

    const detailResults = await Promise.all(
      blogs.map(async (item) => {
        const detailResponse = await fetch(`${apiUrl}/v1/blogs/${item.slug}`, {
          headers: {
            'x-api-key': apiKey,
          },
        });

        if (!detailResponse.ok) {
          return null;
        }

        const detailData = (await detailResponse.json()) as EasyBlogDetailResponse;
        return detailData?.blog ? { params: { slug: item.slug }, props: { post: detailData.blog } } : null;
      })
    );

    return detailResults.filter(Boolean);
  } catch (error) {
    return [];
  }
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={post?.excerpt || post?.title || 'Blog post'} />
    <title>{post?.title ? `${post.title} | Blog` : 'Blog'}</title>
    <ViewTransitions />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  </head>

  <body>
    <Masthead />

    <main class="blog-main">
      {post ? (
        <article class="blog-post">
          <header class="blog-post-header">
            <p class="blog-kicker">{post.category || 'Article'}</p>
            <h1>{post.title}</h1>
            <p class="blog-subhead">{post.excerpt}</p>
            <div class="blog-meta">
              <span>{post.created_at ? new Date(post.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' }) : 'New'}</span>
              <span class="blog-dot"></span>
              <span>{personalInfo.name}</span>
            </div>
          </header>

          {getCoverImage(post) ? (
            <div class="blog-post-media">
              <img src={getCoverImage(post)} alt={post.title} loading="lazy" />
            </div>
          ) : null}

          <div class="blog-content" set:html={post.html_content || post.html || post.content_html || post.content || ''}></div>
        </article>
      ) : (
        <div class="blog-empty">
          <h2>Post not found.</h2>
          <p>Double-check the URL or head back to the blog list.</p>
        </div>
      )}
    </main>

    <FooterSection personalInfo={personalInfo} />
  </body>
</html>
