---
import '../../styles/global.css';
import '../../styles/blog.css';
import { personalInfo } from '../../data/portfolio';
import Masthead from '../../components/Masthead.astro';
import FooterSection from '../../components/FooterSection.astro';
import { getCached } from '../../lib/hive-cache';
import { ClientRouter } from 'astro:transitions';
import type { PostSummary, PostDetail } from '../../types/hive';

const apiBaseUrl = import.meta.env.HIVE_API_URL ?? 'https://api.hivecms.online/api/public/v1';
const apiKey = import.meta.env.HIVE_API_KEY;
const slugParam = Astro.params.slug;

let { post } = Astro.props as { post: PostDetail | null };

if (import.meta.env.SSR && apiKey && slugParam && !post) {
  try {
    const response = await fetch(`${apiBaseUrl}/${apiKey}/posts/${slugParam}`);
    if (response.ok) {
      post = (await response.json()) as PostDetail;
    }
  } catch (error) {
    // fallback to empty state
  }
}

const getCoverImage = (post: unknown) => {
  if (!post || typeof post !== 'object') return '';
  const record = post as Record<string, unknown>;
  const candidates = [
    record.coverImage,
    record.cover_image,
    record.image,
    record.thumbnail,
    record.thumbnail_url,
    record.featured_image,
    record.hero_image,
  ];

  const found = candidates.find((item) => typeof item === 'string');
  return typeof found === 'string' ? found : '';
};

export async function getStaticPaths() {
  if (import.meta.env.SSR) {
    return [];
  }

  const apiBaseUrl = import.meta.env.HIVE_API_URL ?? 'https://api.hivecms.online/api/public/v1';
  const apiKey = import.meta.env.HIVE_API_KEY;

  if (!apiKey) {
    return [];
  }

  try {
    const listUrl = new URL(`${apiBaseUrl}/${apiKey}/posts`);
    listUrl.searchParams.set('limit', '100');

    const listData = await getCached('hive:list', async () => {
      const listResponse = await fetch(listUrl.toString(), {
        headers: {},
      });

      if (!listResponse.ok) {
        return { data: [] as PostSummary[] };
      }

      return (await listResponse.json()) as { data: PostSummary[] };
    });

    const blogs = Array.isArray(listData?.data) ? listData.data : [];

    const detailResults = await Promise.all(
      blogs.map(async (item) => {
        const detailData = await getCached(`hive:post:${item.slug}`, async () => {
          const detailResponse = await fetch(`${apiBaseUrl}/${apiKey}/posts/${item.slug}`, {
            headers: {},
          });

          if (!detailResponse.ok) {
            return null;
          }

          return (await detailResponse.json()) as PostDetail;
        });

        return detailData ? { params: { slug: item.slug }, props: { post: detailData } } : null;
      })
    );

    return detailResults.filter(Boolean);
  } catch (error) {
    return [];
  }
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={post?.excerpt || post?.title || 'Blog post'} />
    <title>{post?.title ? `${post.title} | Blog` : 'Blog'}</title>
    <ClientRouter />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  </head>

  <body class="blog-page">
    <Masthead />

    <main class="blog-main">
      {post ? (
        <article class="blog-post">
          <a class="blog-back" href="/blog">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M19 12H5"></path>
              <path d="M12 19l-7-7 7-7"></path>
            </svg>
            All posts
          </a>
          <header class="blog-post-header">
            <div class="blog-kicker-row">
              <p class="blog-kicker">{post.category?.name || 'Blog'}</p>
              <span class="blog-kicker-date">
                {post.publishedAt ? new Date(post.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' }) : 'New'}
              </span>
            </div>
            <h1>{post.title}</h1>
            <!-- <p class="blog-subhead">{post.excerpt}</p> -->
            <div class="blog-meta">
              <span>{post?.author?.name}</span>
            </div>
          </header>

          {getCoverImage(post) ? (
            <div class="blog-post-media">
              <img src={getCoverImage(post)} alt={post.title} loading="lazy" />
            </div>
          ) : null}

          <div class="blog-content" set:html={post.htmlContent || ''}></div>
        </article>
      ) : (
        <div class="blog-empty">
          <a class="blog-back" href="/blog">← All posts</a>
          <h2>Post not found.</h2>
          <p>Double-check the URL or head back to the blog list.</p>
        </div>
      )}
    </main>

    <FooterSection personalInfo={personalInfo} />
  </body>
</html>
