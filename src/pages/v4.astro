---
// Version 4: Retro Grainy / Vintage Film Aesthetic
// Inspired by: 70s film grain, vintage photography, analog warmth
// Aesthetic: Warm sepia tones, noise textures, rounded retro typography
import { personalInfo, skills, projects, neovimHighlight, siteMetadata } from '../data/portfolio';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={siteMetadata.description} />
    <title>{siteMetadata.title} | v4</title>
    
    <!-- Retro fonts: Libre Baskerville + DM Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
      :root {
        --bg: #f4efe6;
        --bg-dark: #2c2418;
        --cream: #faf6ed;
        --warm-white: #fffdf8;
        --brown: #5c4934;
        --brown-light: #8b7355;
        --orange: #e07b39;
        --rust: #c45d2c;
        --olive: #6b7c52;
        --text: #3d3428;
        --text-light: #7a6f5f;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        font-size: 16px;
        scroll-behavior: smooth;
      }

      body {
        font-family: 'Libre Baskerville', serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.8;
        position: relative;
      }

      /* Film Grain Overlay */
      body::before {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 9999;
        opacity: 0.4;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      }

      /* Vignette effect */
      body::after {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 9998;
        background: radial-gradient(ellipse at center, transparent 40%, rgba(44, 36, 24, 0.15) 100%);
      }

      ::selection {
        background: var(--orange);
        color: var(--cream);
      }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
        position: relative;
        z-index: 1;
      }

      /* Navigation */
      nav {
        padding: 2rem 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid var(--brown-light);
      }

      .nav-logo {
        font-family: 'Syne', sans-serif;
        font-size: 1.8rem;
        font-weight: 800;
        color: var(--brown);
        letter-spacing: -0.02em;
      }

      .nav-links {
        display: flex;
        gap: 2.5rem;
        list-style: none;
      }

      .nav-links a {
        font-family: 'Syne', sans-serif;
        color: var(--text-light);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        transition: color 0.3s ease;
      }

      .nav-links a:hover {
        color: var(--orange);
      }

      /* Hero Section */
      .hero {
        padding: 8rem 0;
        text-align: center;
        position: relative;
      }

      .hero-badge {
        display: inline-block;
        font-family: 'Syne', sans-serif;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: var(--cream);
        background: var(--brown);
        padding: 0.5rem 1.5rem;
        border-radius: 50px;
        margin-bottom: 3rem;
      }

      .hero-name {
        font-size: clamp(3rem, 10vw, 7rem);
        font-weight: 700;
        line-height: 1;
        color: var(--brown);
        margin-bottom: 2rem;
        letter-spacing: -0.03em;
      }

      .hero-name span {
        display: block;
        color: var(--orange);
        font-style: italic;
        font-weight: 400;
      }

      .hero-tagline {
        font-size: 1.2rem;
        font-style: italic;
        color: var(--text-light);
        max-width: 500px;
        margin: 0 auto 3rem;
      }

      .hero-cta {
        display: inline-flex;
        align-items: center;
        gap: 1rem;
        font-family: 'Syne', sans-serif;
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--cream);
        background: var(--rust);
        padding: 1rem 2.5rem;
        border-radius: 50px;
        text-decoration: none;
        transition: all 0.3s ease;
        box-shadow: 4px 4px 0 var(--brown);
      }

      .hero-cta:hover {
        transform: translate(-2px, -2px);
        box-shadow: 6px 6px 0 var(--brown);
      }

      /* Decorative elements */
      .deco-circle {
        position: absolute;
        border: 2px solid var(--brown-light);
        border-radius: 50%;
        opacity: 0.3;
      }

      .deco-circle.one {
        width: 300px;
        height: 300px;
        top: 10%;
        left: -150px;
      }

      .deco-circle.two {
        width: 200px;
        height: 200px;
        bottom: 20%;
        right: -100px;
      }

      /* Section styling */
      section {
        padding: 6rem 0;
      }

      .section-header {
        text-align: center;
        margin-bottom: 4rem;
      }

      .section-label {
        font-family: 'Syne', sans-serif;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.3em;
        color: var(--orange);
        margin-bottom: 1rem;
      }

      .section-title {
        font-size: 2.5rem;
        color: var(--brown);
      }

      /* Vintage Card */
      .vintage-card {
        background: var(--cream);
        border: 2px solid var(--brown);
        padding: 3rem;
        position: relative;
        box-shadow: 8px 8px 0 var(--brown-light);
      }

      .vintage-card::before {
        content: '';
        position: absolute;
        top: 0.5rem;
        left: 0.5rem;
        right: 0.5rem;
        bottom: 0.5rem;
        border: 1px solid var(--brown-light);
        pointer-events: none;
      }

      /* About Section */
      .about-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: start;
      }

      .about-text {
        font-size: 1.1rem;
        line-height: 2;
      }

      .about-text p + p {
        margin-top: 1.5rem;
      }

      .about-image {
        aspect-ratio: 3/4;
        background: linear-gradient(135deg, var(--brown-light) 0%, var(--brown) 100%);
        position: relative;
        overflow: hidden;
      }

      .about-image::after {
        content: 'PHOTO';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        font-family: 'Syne', sans-serif;
        font-size: 1rem;
        color: var(--cream);
        opacity: 0.3;
        letter-spacing: 0.2em;
      }

      /* Neovim Highlight - Stamp style */
      .neovim-stamp {
        background: var(--bg-dark);
        color: var(--cream);
        padding: 4rem;
        margin: 4rem 0;
        position: relative;
        transform: rotate(-1deg);
      }

      .neovim-stamp::before {
        content: 'FEATURED';
        position: absolute;
        top: -15px;
        right: 2rem;
        font-family: 'Syne', sans-serif;
        font-size: 0.7rem;
        font-weight: 700;
        color: var(--bg-dark);
        background: var(--orange);
        padding: 0.4rem 1rem;
        letter-spacing: 0.1em;
        transform: rotate(3deg);
      }

      .neovim-icon {
        font-family: 'Syne', sans-serif;
        font-size: 4rem;
        font-weight: 800;
        color: var(--olive);
        margin-bottom: 1.5rem;
      }

      .neovim-title {
        font-family: 'Syne', sans-serif;
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 1rem;
        color: var(--cream);
      }

      .neovim-desc {
        font-size: 1rem;
        line-height: 1.9;
        color: var(--brown-light);
        max-width: 600px;
      }

      /* Skills Section */
      .skills-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2rem;
      }

      .skill-card {
        background: var(--cream);
        border: 2px solid var(--brown);
        padding: 2rem;
        text-align: center;
        transition: all 0.3s ease;
      }

      .skill-card:hover {
        transform: translateY(-5px);
        box-shadow: 5px 5px 0 var(--orange);
      }

      .skill-card-title {
        font-family: 'Syne', sans-serif;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--orange);
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: 1px dashed var(--brown-light);
      }

      .skill-list {
        list-style: none;
      }

      .skill-item {
        font-size: 0.95rem;
        padding: 0.5rem 0;
        color: var(--text);
      }

      .skill-item.highlight {
        font-weight: 700;
        color: var(--rust);
      }

      /* Projects Section */
      .projects-grid {
        display: grid;
        gap: 3rem;
      }

      .project-card {
        display: grid;
        grid-template-columns: 1fr 1.5fr;
        gap: 3rem;
        padding: 3rem;
        background: var(--cream);
        border: 2px solid var(--brown);
        transition: all 0.3s ease;
      }

      .project-card:nth-child(even) {
        grid-template-columns: 1.5fr 1fr;
      }

      .project-card:nth-child(even) .project-media {
        order: 2;
      }

      .project-card:hover {
        box-shadow: 8px 8px 0 var(--orange);
      }

      .project-media {
        aspect-ratio: 16/10;
        background: linear-gradient(135deg, var(--brown-light) 0%, var(--brown) 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Syne', sans-serif;
        font-size: 2rem;
        font-weight: 800;
        color: rgba(255,255,255,0.1);
      }

      .project-content {
        display: flex;
        flex-direction: column;
        justify-content: center;
      }

      .project-number {
        font-family: 'Syne', sans-serif;
        font-size: 0.7rem;
        font-weight: 600;
        color: var(--orange);
        letter-spacing: 0.2em;
        margin-bottom: 0.5rem;
      }

      .project-name {
        font-size: 2rem;
        color: var(--brown);
        margin-bottom: 1rem;
      }

      .project-desc {
        font-size: 0.95rem;
        color: var(--text-light);
        line-height: 1.8;
        margin-bottom: 2rem;
        font-style: italic;
      }

      .project-links {
        display: flex;
        gap: 1.5rem;
      }

      .project-link {
        font-family: 'Syne', sans-serif;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--brown);
        text-decoration: none;
        padding: 0.5rem 0;
        border-bottom: 2px solid var(--brown);
        transition: all 0.3s ease;
      }

      .project-link:hover {
        color: var(--orange);
        border-bottom-color: var(--orange);
      }

      /* Contact Section */
      .contact-card {
        text-align: center;
        padding: 5rem;
      }

      .contact-headline {
        font-size: 2.5rem;
        color: var(--brown);
        margin-bottom: 2rem;
      }

      .contact-headline span {
        color: var(--orange);
        font-style: italic;
      }

      .contact-email {
        display: inline-block;
        font-family: 'Syne', sans-serif;
        font-size: 1.2rem;
        font-weight: 600;
        color: var(--cream);
        background: var(--rust);
        padding: 1rem 3rem;
        border-radius: 50px;
        text-decoration: none;
        margin: 2rem 0;
        box-shadow: 4px 4px 0 var(--brown);
        transition: all 0.3s ease;
      }

      .contact-email:hover {
        transform: translate(-2px, -2px);
        box-shadow: 6px 6px 0 var(--brown);
      }

      .contact-socials {
        display: flex;
        justify-content: center;
        gap: 2rem;
        margin-top: 3rem;
      }

      .social-link {
        font-family: 'Syne', sans-serif;
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--text-light);
        text-decoration: none;
        transition: color 0.3s ease;
      }

      .social-link:hover {
        color: var(--orange);
      }

      /* Footer */
      footer {
        text-align: center;
        padding: 3rem;
        border-top: 2px solid var(--brown);
        margin-top: 4rem;
      }

      .footer-text {
        font-size: 0.85rem;
        color: var(--text-light);
      }

      .footer-year {
        font-family: 'Syne', sans-serif;
        font-size: 5rem;
        font-weight: 800;
        color: var(--brown);
        opacity: 0.1;
        margin-bottom: 1rem;
      }

      /* Responsive */
      @media (max-width: 1024px) {
        .about-grid {
          grid-template-columns: 1fr;
        }

        .about-image {
          display: none;
        }

        .skills-grid {
          grid-template-columns: repeat(2, 1fr);
        }

        .project-card,
        .project-card:nth-child(even) {
          grid-template-columns: 1fr;
        }

        .project-card:nth-child(even) .project-media {
          order: 0;
        }
      }

      @media (max-width: 768px) {
        .container {
          padding: 0 1.5rem;
        }

        .nav-links {
          display: none;
        }

        .hero-name {
          font-size: 3rem;
        }

        .skills-grid {
          grid-template-columns: 1fr;
        }

        .contact-card {
          padding: 3rem 1.5rem;
        }

        .deco-circle {
          display: none;
        }
      }
    </style>
  </head>
  
  <body>
    <div class="container">
      <!-- Navigation -->
      <nav>
        <span class="nav-logo">RP.</span>
        <ul class="nav-links">
          <li><a href="#about">About</a></li>
          <li><a href="#skills">Skills</a></li>
          <li><a href="#work">Work</a></li>
          <li><a href="#contact">Contact</a></li>
        </ul>
      </nav>

      <!-- Hero -->
      <section class="hero">
        <div class="deco-circle one"></div>
        <div class="deco-circle two"></div>
        
        <span class="hero-badge">Frontend Developer</span>
        <h1 class="hero-name">
          {personalInfo.firstName}
          <span>{personalInfo.lastName}</span>
        </h1>
        <p class="hero-tagline">"{personalInfo.tagline}"</p>
        <a href="#work" class="hero-cta">
          View My Work
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </section>

      <!-- About Section -->
      <section id="about">
        <div class="section-header">
          <span class="section-label">Get to Know Me</span>
          <h2 class="section-title">About</h2>
        </div>

        <div class="about-grid">
          <div class="about-text">
            <p>{personalInfo.bio.split('\n\n')[0]}</p>
            <p>{personalInfo.bio.split('\n\n')[1]}</p>
            <p style="margin-top: 2rem;">
              <strong>Location:</strong> {personalInfo.location.full}<br>
              <strong>Education:</strong> {personalInfo.education.year} at {personalInfo.education.institution}
            </p>
          </div>
          <div class="vintage-card about-image"></div>
        </div>

        <!-- Neovim Stamp -->
        <div class="neovim-stamp">
          <div class="neovim-icon">vim</div>
          <h3 class="neovim-title">{neovimHighlight.title}</h3>
          <p class="neovim-desc">{neovimHighlight.description}</p>
        </div>
      </section>

      <!-- Skills Section -->
      <section id="skills">
        <div class="section-header">
          <span class="section-label">What I Work With</span>
          <h2 class="section-title">Skills & Tools</h2>
        </div>

        <div class="skills-grid">
          <div class="skill-card">
            <h3 class="skill-card-title">Primary Stack</h3>
            <ul class="skill-list">
              {skills.filter(s => s.category === 'primary').map(skill => (
                <li class="skill-item">{skill.name}</li>
              ))}
            </ul>
          </div>

          <div class="skill-card">
            <h3 class="skill-card-title">Languages</h3>
            <ul class="skill-list">
              {skills.filter(s => s.category === 'language').map(skill => (
                <li class="skill-item">{skill.name}</li>
              ))}
            </ul>
          </div>

          <div class="skill-card">
            <h3 class="skill-card-title">Tools</h3>
            <ul class="skill-list">
              {skills.filter(s => s.category === 'tool').map(skill => (
                <li class={`skill-item ${skill.name === 'Neovim' ? 'highlight' : ''}`}>{skill.name}</li>
              ))}
            </ul>
          </div>

          <div class="skill-card">
            <h3 class="skill-card-title">Databases</h3>
            <ul class="skill-list">
              {skills.filter(s => s.category === 'database').map(skill => (
                <li class="skill-item">{skill.name}</li>
              ))}
            </ul>
          </div>
        </div>
      </section>

      <!-- Projects Section -->
      <section id="work">
        <div class="section-header">
          <span class="section-label">Selected Projects</span>
          <h2 class="section-title">My Work</h2>
        </div>

        <div class="projects-grid">
          {projects.map((project, index) => (
            <article class="project-card">
              <div class="project-media">{project.name.split(' ')[0]}</div>
              <div class="project-content">
                <span class="project-number">Project {String(index + 1).padStart(2, '0')}</span>
                <h3 class="project-name">{project.name}</h3>
                <p class="project-desc">
                  {project.description || 'Project details coming soon. This showcase will feature the challenge, solution, and impact.'}
                </p>
                <div class="project-links">
                  <a href={project.githubUrl || '#'} class="project-link">GitHub</a>
                  <a href={project.deployedUrl || '#'} class="project-link">View Live</a>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      <!-- Contact Section -->
      <section id="contact">
        <div class="vintage-card contact-card">
          <h2 class="contact-headline">
            Let's <span>connect</span> and create
          </h2>
          <p style="color: var(--text-light); max-width: 400px; margin: 0 auto;">
            I'm always open to discussing new projects, creative ideas, or opportunities.
          </p>
          <a href={`mailto:${personalInfo.email}`} class="contact-email">
            Say Hello
          </a>
          <div class="contact-socials">
            {personalInfo.socials.map(social => (
              <a href={social.url} class="social-link" target="_blank" rel="noopener noreferrer">
                {social.platform}
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- Footer -->
      <footer>
        <div class="footer-year">2024</div>
        <p class="footer-text">&copy; {personalInfo.name} / Made with love and Neovim</p>
      </footer>
    </div>
  </body>
</html>
